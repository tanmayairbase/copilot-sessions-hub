{
  "name": "agentstash",
  "productName": "AgentStash",
  "version": "11.0.0",
  "description": "A single place to search, read and persist every AI coding session — Copilot, OpenCode, and Claude Code — kept locally forever.",
  "repository": {
    "type": "git",
    "url": "https://github.com/tanmayairbase/AgentStash.git"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "postinstall": "node node_modules/electron/install.js",
    "dev": "electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "build:dir": "pnpm build && electron-builder --dir",
    "package": "pnpm build && electron-builder",
    "package:mac": "pnpm build && electron-builder --mac dmg",
    "package:win": "pnpm build && electron-builder --win nsis --x64",
    "package:win:arm64": "pnpm build && electron-builder --win nsis --arm64",
    "test": "vitest run --coverage",
    "format": "prettier --write .",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "ansi-to-html": "^0.7.2",
    "clsx": "^2.1.1",
    "fast-glob": "^3.3.3",
    "marked": "^17.0.4",
    "mermaid": "^11.16.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "41.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.local.agentstash",
    "productName": "AgentStash",
    "files": [
      "out/**",
      "node_modules/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "icon": "build/icons/agentstash.icns",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icons/agentstash.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "packageManager": "pnpm@10.28.1"
}
